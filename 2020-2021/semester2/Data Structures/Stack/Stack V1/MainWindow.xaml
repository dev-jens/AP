<Window x:Class="Stack_V1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Stack_V1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="inputBox" HorizontalAlignment="Left" Height="37" Margin="88,104,0,0"  TextWrapping="Wrap" VerticalAlignment="Top" Width="196"/>
        <ListBox x:Name="outputBox" HorizontalAlignment="Left" Height="199" Margin="88,178,0,0" VerticalAlignment="Top" Width="196"/>
        <Button x:Name="Push_btn" Content="Push" HorizontalAlignment="Left" Height="49" Margin="304,178,0,0" VerticalAlignment="Top" Width="133" Click="Push_btn_Click"/>
        <Button x:Name="Pop_btn" Content="Pop&#xD;&#xA;" HorizontalAlignment="Left" Margin="304,254,0,0" VerticalAlignment="Top" Height="46" Width="133" Click="Pop_btn_Click"/>

    </Grid>
</Window>
